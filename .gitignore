# dependencies
node_modules/

# TypeScript build output (regenerated by `tsc`; npm-published via prepublish)
dist/

# Rust build output (huge; regenerated by cargo)
crate/target/

# extension bundle output (regenerated by `npm run build:ext`)
examples/extension/build/

# macOS / editors
.DS_Store
*.log

# secrets & sensitive material — NEVER commit (defensive; keys are user-supplied
# at runtime, never checked in). Spending keys, viewing keys, env, proving params.
.env
.env.*
*.key
*.pem
*extsk*
*spending-key*
*secret-extended-key*
*.params
zcash-params/

# NOTE: crate/pkg/ (the wasm-pack output) IS committed on purpose — it's the
# shipped prover artifact and lets a fresh clone typecheck without a Rust +
# wasm-pack toolchain. Rebuild it with `wasm-pack build --target web --release`.
