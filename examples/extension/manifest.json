{
  "manifest_version": 3,
  "name": "Verus Shielded Demo",
  "version": "0.0.1",
  "description": "Sign private (Sapling) Verus transactions entirely client-side — no full node.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Verus Shielded Demo"
  },
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8080/*", "http://localhost:8081/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' http://localhost:8080 http://localhost:8081"
  }
}
